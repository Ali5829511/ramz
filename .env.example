# ملف متغيرات البيئة - انسخه إلى .env واملأ القيم
# احصل على هذه القيم من: https://supabase.com > مشروعك > Settings > API

NODE_ENV=production
PORT=3000
TRUST_PROXY=true
FORCE_HTTPS=true

# اختياري - تحليلات Umami
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE
